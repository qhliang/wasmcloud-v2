package custom:llm-gateway@0.1.0;

/// Types used by components and providers of the LLM Gateway interface.
/// Mirrors genai's common message types for rich content support.
interface types {
    /// Errors that can occur when calling LLM providers
    variant llm-error {
        invalid-request(string),
        authentication-error(string),
        provider-error(string),
        rate-limit-error(string),
        model-not-found(string),
        unexpected(string),
    }

    /// Chat message role
    enum chat-role {
        system,
        user,
        assistant,
        tool,
    }

    /// Source of a binary payload
    variant binary-source {
        url(string),
        base64(string),
    }

    /// Binary content (images, PDFs, etc.)
    record binary-part {
        content-type: string,
        source: binary-source,
        name: option<string>,
    }

    /// A tool call returned by the model
    record tool-call {
        call-id: string,
        fn-name: string,
        /// JSON string of the function arguments
        fn-arguments: string,
    }

    /// A tool response provided back to the model
    record tool-response {
        call-id: string,
        content: string,
    }

    /// A single content segment in a chat message.
    /// Mirrors genai's ContentPart. Omits ThoughtSignature,
    /// ReasoningContent, and Custom variants (provider-internal).
    variant content-part {
        text(string),
        binary(binary-part),
        tool-call(tool-call),
        tool-response(tool-response),
    }

    /// Message content is a list of content parts.
    record message-content {
        parts: list<content-part>,
    }

    /// A single message in a chat conversation
    record chat-message {
        role: chat-role,
        content: message-content,
    }

    /// Reason the generation finished
    variant stop-reason {
        completed(string),
        max-tokens(string),
        tool-call(string),
        content-filter(string),
        stop-sequence(string),
        other(string),
    }

    /// Token usage statistics
    record token-usage {
        prompt-tokens: u64,
        completion-tokens: u64,
        total-tokens: u64,
    }

    /// Response from a chat completion
    record chat-response {
        content: message-content,
        model: string,
        stop-reason: option<stop-reason>,
        usage: option<token-usage>,
    }

    /// Options for chat completion
    record chat-options {
        temperature: option<f32>,
        max-tokens: option<u32>,
        top-p: option<f32>,
    }

    /// A single chunk of streamed chat content
    record chat-chunk {
        content-delta: string,
    }

    /// Information provided when the stream ends
    record stream-end {
        model: string,
        usage: option<token-usage>,
        stop-reason: option<stop-reason>,
    }

    /// Event emitted during a streaming chat response
    variant chat-stream-event {
        chunk(chat-chunk),
        end(stream-end),
        error(string),
    }

    /// Dynamic configuration for a single chat/streaming request.
    /// When provided, these values override the interface-level config.
    record llm-config {
        api-key: string,
        base-url: option<string>,
    }
}

/// Interface for LLM chat completions
interface chat {
    use types.{llm-error, chat-message, chat-response, chat-options, llm-config};

    /// Execute a chat completion request.
    chat: func(model: string, messages: list<chat-message>, options: option<chat-options>, config: option<llm-config>) -> result<chat-response, llm-error>;
}

/// Interface for streaming LLM chat completions
interface chat-streaming {
    use types.{llm-error, chat-message, chat-options, chat-stream-event, llm-config};

    /// A resource representing an ongoing streaming chat response.
    resource chat-stream {
        /// Read the next batch of events from the stream.
        next: func() -> result<tuple<list<chat-stream-event>, bool>, llm-error>;
    }

    /// Start a streaming chat completion request.
    chat-streaming: func(model: string, messages: list<chat-message>, options: option<chat-options>, config: option<llm-config>) -> result<chat-stream, llm-error>;
}

/// World defining the LLM Gateway interface
world llm-gateway {
    import chat;
    import chat-streaming;
}
