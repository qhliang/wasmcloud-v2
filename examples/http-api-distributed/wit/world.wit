package wasmcloud:template@0.1.0;

// wasi:http/incoming-handler is exported via wstd's #[http_server] proc macro,
// so it does not appear explicitly in this world definition.
world http-api {
  import wasmcloud:messaging/consumer@0.2.0;
  import wasi:keyvalue/store@0.2.0-draft;
  import wasi:blobstore/types@0.2.0-draft;
  import wasi:blobstore/container@0.2.0-draft;
  import wasi:blobstore/blobstore@0.2.0-draft;
  import wasi:clocks/monotonic-clock@0.2.1;
  import wasi:logging/logging@0.1.0-draft;
  import custom:cf-d1/query@0.1.0;
  import custom:llm-gateway/chat@0.1.0;
  import custom:crontab/scheduler@0.1.0;
  import custom:dingtalk-stream/sender@0.1.0;
  import custom:feishu/sender@0.1.0;
  import custom:mail/sender@0.1.0;
  import custom:wechat/sender@0.1.0;
  import custom:codex/executor@0.1.0;
  import custom:codex/session@0.1.0;
  import custom:telegram/sender@0.1.0;

  export custom:dingtalk-stream/handler@0.1.0;
  export custom:feishu/handler@0.1.0;
  export custom:crontab/handler@0.1.0;
  export custom:wechat/handler@0.1.0;
  export custom:telegram/handler@0.1.0;
}

world task {
  import wasmcloud:messaging/consumer@0.2.0;
  import wasi:logging/logging@0.1.0-draft;
  export wasmcloud:messaging/handler@0.2.0;
}
